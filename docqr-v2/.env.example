# ============================================
# DOCQR V2 - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database (PostgreSQL)
DATABASE_URL=postgresql://docqr:docqr_secret@localhost:5432/docqr
DB_USER=docqr
DB_PASSWORD=docqr_secret
DB_NAME=docqr
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
# Or use connection URL (for Railway)
# REDIS_URL=redis://:redis_secret@localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Storage (MinIO / S3 Compatible)
USE_LOCAL_STORAGE=false
USE_MINIO=true
UPLOADS_DIR=./uploads
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_QRCODES=qr-codes

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/jpeg,image/png,image/gif,image/webp

# QR Code
QR_CODE_SIZE=300
QR_CODE_ERROR_CORRECTION=M
APP_BASE_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=*

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@docqr.local
EMAIL_FROM_NAME=DOCQR System

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# OnlyOffice Document Server
ONLYOFFICE_URL=http://localhost:8080
ONLYOFFICE_JWT_SECRET=onlyoffice_jwt_secret

# Logging
LOG_LEVEL=debug

# Railway Detection (auto-detected)
# RAILWAY_ENVIRONMENT=production
# TRUST_PROXY=true

# ============================================
# Docker Compose Settings
# ============================================
DB_USER=docqr
DB_PASSWORD=docqr_secret
DB_NAME=docqr
REDIS_PASSWORD=redis_secret
PGADMIN_EMAIL=admin@docqr.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
MINIO_CONSOLE_PORT=9001
ONLYOFFICE_PORT=8080
