{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Port": 5000,
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=docqr;Username=docqr;Password=docqr_dev_password"
  },
  "Jwt": {
    "Secret": "your-256-bit-secret-key-for-jwt-signing-minimum-32-chars",
    "Issuer": "docqr",
    "Audience": "docqr-client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Storage": {
    "Provider": "local",
    "LocalPath": "./uploads",
    "DocumentsBucket": "docqr-documents",
    "QrCodesBucket": "docqr-qrcodes",
    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "UseSSL": false
    }
  },
  "Cors": {
    "Origins": ["http://localhost:5173", "http://localhost:3000"]
  },
  "OnlyOffice": {
    "ServerUrl": "http://localhost:8080",
    "JwtSecret": "onlyoffice_jwt_secret",
    "JwtEnabled": true,
    "HostIp": "host.docker.internal"
  }
}
